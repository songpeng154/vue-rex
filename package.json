{
  "name": "vue-rex",
  "type": "module",
  "version": "1.1.20",
  "description": "Vue Rex 是一个面向 Vue 3 的高度灵活、类型安全且插件化的请求 Hook 库，支持多后端适配、缓存、分页、插件化扩展等特性。",
  "author": {
    "email": "419626398@qq.com",
    "name": "songpeng154",
    "url": "https://github.com/songpeng154"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/songpeng154/vue-rex.git"
  },
  "keywords": [
    "axios",
    "vue-request",
    "ahooks",
    "vue-query",
    "react-query",
    "vue-rex",
    "vue-hooks"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "README.md",
    "dist"
  ],
  "engines": {
    "node": ">=18.12.0",
    "pnpm": ">=8.7.0"
  },
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "docs": "pnpm -C docs dev",
    "docs:build": "pnpm -C docs build",
    "docs:preview": "pnpm -C docs preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint-staged": "lint-staged",
    "type-check": "vue-tsc --noEmit",
    "tag": "bumpp",
    "publish:npm": "npm publish --access public"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "dependencies": {
    "@vueuse/core": "^12.8.2",
    "es-toolkit": "^1.46.1",
    "mitt": "^3.0.1",
    "type-fest": "^5.6.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.19.0",
    "@faker-js/faker": "^10.4.0",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "^22.19.17",
    "@vitest/ui": "^4.1.5",
    "@vue/test-utils": "^2.4.10",
    "axios": "^1.15.2",
    "bumpp": "^10.4.1",
    "eslint": "^9.39.4",
    "happy-dom": "^17.6.3",
    "lint-staged": "^15.5.2",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3",
    "vite": "^6.0.0",
    "vitest": "^4.1.5",
    "vue-tsc": "^2.2.12"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
